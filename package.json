{
  "name": "@institute-alterna/talent",
  "version": "1.0.0",
  "description": "Internal talent management system for the recruitment of Alterna personnel",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "deploy": "npm run db:generate && npm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "tsx --test tests/**/*.integration.test.ts",
    "test:all": "npm run test && npm run test:integration",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
    "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
    "repository": {
    "type": "git",
    "url": "git+https://github.com/institute-alterna/talent.git"
  },
  "author": "Institute Alterna",
  "license": "MIT",
